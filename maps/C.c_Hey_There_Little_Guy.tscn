[sub_resource type="GDScript" id="GDScript_fpyyo"]
script/source = "extends Node


func _on_captured():
	var region : Region = get_parent() as Region
	
	if region:
		region.reinforce(region.alignment, 2)
		if region.region_control and region.region_control.game_camera:
			region.region_control.game_camera.shake_camera(2, 20, 0.5)
"

