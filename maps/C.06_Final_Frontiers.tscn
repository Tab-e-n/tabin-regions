[sub_resource type="GDScript" id="GDScript_63lwb"]
script/source = "extends Node


const INV160 : float = 1.0 / 160.0


@export var rotation_speed : float = 0.0015 * PI

@onready var parent = get_parent() as GroupAnimator


var end : bool = false
var speed : float = 0


func _process(delta):
	parent.rotate(rotation_speed * delta)
	if end:
		for i in parent.get_children():
			var node : Node2D = i as Node2D
			if node:
				node.position = node.position.move_toward(Vector2(0, 0), speed)
				var dist = node.position.distance_to(Vector2(0, 0))
				if dist < 160:
					node.scale = Vector2(dist * INV160, dist * INV160)
		speed += 0.125 * delta
		parent.update_object_scale()
	parent.update_object_positions()


func _map_ended(_align_win):
	end = true
"

[sub_resource type="GDScript" id="GDScript_rbnma"]
script/source = "extends Node2D


func _process(delta):
	rotate(0.0025 * PI * delta)
	$\"Bendy Layer\".rotate(0.0005 * PI * delta)
	$\"Bendy Layer/Event Horizon\".rotate(0.0005 * PI * delta)
"

