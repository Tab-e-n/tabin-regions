[sub_resource type="GDScript" id="GDScript_hjewa"]
script/source = "extends Node


const BOUNDS : Vector2 = Vector2(64, 96)


@onready var parent : Node2D = get_parent() as Node2D


var bounds : Vector4 = Vector4(0, 0, 0, 0)
var dir : Vector2 = Vector2(1.0, 1.0)


func _ready():
	bounds.x = BOUNDS.x + parent.position.x
	bounds.y = -BOUNDS.x + parent.position.x
	bounds.z = BOUNDS.y + parent.position.y
	bounds.w = -BOUNDS.y + parent.position.y


func _process(delta):
	parent.position += dir * delta
	
	if parent.position.x > bounds.x:
		dir.x = -1.0
	if parent.position.x < bounds.y:
		dir.x = 1.0
	if parent.position.y > bounds.z:
		dir.y = -1.0
	if parent.position.y < bounds.w:
		dir.y = 1.0
"

