[sub_resource type="GDScript" id="GDScript_sgqnx"]
script/source = "extends Node


const SPEED : float = 2


@export var top_side : Array[NodePath] = []
@export var bottom_side : Array[NodePath] = []
@export var star_spawner : Node2D

var top_side_nodes : Array[Node2D] = []
var bottom_side_nodes : Array[Node2D] = []
var top_side_pos : Array[Vector2] = []
var bottom_side_pos : Array[Vector2] = []

var current_side : bool = true
var animating : bool = false

var top_alpha : float = 1.0
var bottom_alpha : float = 0.0


func _ready():
	for path in top_side:
		var node : Node2D = get_node(path) as Node2D
		if node:
			top_side_nodes.append(node)
			top_side_pos.append(node.position)
	top_side.clear()
	for path in bottom_side:
		var node : Node2D = get_node(path) as Node2D
		if node:
			bottom_side_nodes.append(node)
			bottom_side_pos.append(node.position)
	bottom_side.clear()
	
	call_deferred(\"set_visibility\")


func set_visibility():
	var align = get_parent().current_playing_align
	set_all_visible(top_side_nodes, top_side_pos, align >= 6)
	current_side = align >= 6
	set_all_visible(bottom_side_nodes, bottom_side_pos, align <= 5)
	star_spawner.enabled = align <= 5


func _process(delta):
	var shift = delta * SPEED
	if animating:
		if current_side:
			if top_alpha > 0.0:
				top_alpha -= shift
				set_all_alpha(top_side_nodes, top_alpha)
				if top_alpha <= 0.0:
					set_all_visible(top_side_nodes, top_side_pos, false)
					set_all_visible(bottom_side_nodes, bottom_side_pos, true)
					star_spawner.enabled = true
			elif bottom_alpha < 1.0:
				bottom_alpha += shift
				set_all_alpha(bottom_side_nodes, bottom_alpha)
			else:
				end_animating()
		else:
			if bottom_alpha > 0.0:
				bottom_alpha -= shift
				set_all_alpha(bottom_side_nodes, bottom_alpha)
				if bottom_alpha <= 0.0:
					set_all_visible(top_side_nodes, top_side_pos, true)
					set_all_visible(bottom_side_nodes, bottom_side_pos, false)
					star_spawner.enabled = false
			elif top_alpha < 1.0:
				top_alpha += shift
				set_all_alpha(top_side_nodes, top_alpha)
			else:
				end_animating()


func _on_flip_pressed():
	if not animating:
		start_animating()


func set_all_visible(side : Array[Node2D], side_pos : Array[Vector2], value : bool):
	for i in range(side.size()):
		var node : Node2D = side[i]
		node.visible = value
		if value:
			node.position = side_pos[i]
		else:
			node.position = side_pos[i] * 3.0
		if node is Region:
			node.hide_region_links()


func set_all_alpha(side : Array[Node2D], value : float):
	for node in side:
		node.modulate.a = value


func start_animating():
	animating = true
	if current_side:
		top_alpha = 1.0
		bottom_alpha = 0.0
		set_all_alpha(top_side_nodes, top_alpha)
		set_all_alpha(bottom_side_nodes, bottom_alpha)
	else:
		top_alpha = 0.0
		bottom_alpha = 1.0
		set_all_alpha(top_side_nodes, top_alpha)
		set_all_alpha(bottom_side_nodes, bottom_alpha)


func end_animating():
	animating = false
	current_side = not current_side
	if current_side:
		set_all_visible(top_side_nodes, top_side_pos, true)
		set_all_visible(bottom_side_nodes, bottom_side_pos, false)
		star_spawner.enabled = false
	else:
		set_all_visible(top_side_nodes, top_side_pos, false)
		set_all_visible(bottom_side_nodes, bottom_side_pos, true)
		star_spawner.enabled = true
"

